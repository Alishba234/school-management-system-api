    "name": "School Management API",
    "description": "This collection contains APIs to add schools and retrieve schools sorted by proximity using latitude and longitude.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "School APIs",
      "item": [
        {
          "name": "Add School",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"City School\",\n  \"address\": \"Lahore, Pakistan\",\n  \"latitude\": 31.5204,\n  \"longitude\": 74.3587\n}"
            },
            "url": {
              "raw": "http://localhost:7000/api/addSchool",
              "protocol": "http",
              "host": ["localhost"],
              "port": "7000",
              "path": ["api", "addSchool"]
            }
          }
        },
        {
          "name": "List Schools (By Proximity)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:7000/api/listSchools?latitude=31.5&longitude=74.3",
              "protocol": "http",
              "host": ["localhost"],
              "port": "7000",
              "path": ["api", "listSchools"],
              "query": [
                {
                  "key": "latitude",
                  "value": "31.5"
                },
                {
                  "key": "longitude",
                  "value": "74.3"
                }
              ]
            }
          }
        }
      ]
    }
  ]
